{
  "billing": {
    "mode": "subscription",
    "client": "cursor",
    "contextWindow": 200000
  },
  "embedding": {
    "backend": "local",
    "model": "bge-small-en-v1.5"
  },
  "retrieval": {
    "topK": 6,
    "hybrid": true
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_xxx" }
    },
    "figma": {
      "url": "https://figma.example/mcp"
    }
  }
}
