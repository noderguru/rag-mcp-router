{
  "name": "rag-mcp-router",
  "version": "0.2.0",
  "description": "Open-source RAG router for MCP — sits in front of all your MCP servers and exposes only the relevant tools per query, killing context overload.",
  "license": "Apache-2.0",
  "author": "noderguru <noderguru@gmail.com>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noderguru/rag-mcp-router.git"
  },
  "homepage": "https://github.com/noderguru/rag-mcp-router#readme",
  "bugs": {
    "url": "https://github.com/noderguru/rag-mcp-router/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "rag-mcp-router": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/report-prototype.html",
    "rag-mcp.config.example.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "smoke": "node smoke-test.mjs",
    "bench": "node test/eval/run.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-client",
    "mcp-gateway",
    "mcp-router",
    "rag",
    "tool-selection",
    "tool-search",
    "semantic-search",
    "embeddings",
    "ai-agents",
    "agent-tools",
    "llm",
    "claude",
    "cursor",
    "context-window",
    "context-optimization",
    "token-optimization"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastembed": "^2.1.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ]
  }
}
