{
  "name": "rag-mcp-router",
  "version": "0.1.0",
  "description": "Open-source RAG router for MCP — sits in front of all your MCP servers and exposes only the relevant tools per query, killing context overload.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "rag-mcp-router": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/report-prototype.html",
    "rag-mcp.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "smoke": "node smoke-test.mjs",
    "bench": "node test/eval/run.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rag",
    "tool-selection",
    "ai-agents",
    "context-optimization"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastembed": "^2.1.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ]
  }
}
